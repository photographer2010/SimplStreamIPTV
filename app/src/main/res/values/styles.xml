<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ==================== BASE STYLES (for parent references) ==================== -->
    
    <style name="TextAppearance.SimplStream" parent="android:TextAppearance">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Display" parent="TextAppearance.SimplStream">
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textSize">40sp</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Headline" parent="TextAppearance.SimplStream">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">24sp</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Title" parent="TextAppearance.SimplStream">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.SimplStream.Body" parent="TextAppearance.SimplStream">
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.SimplStream.Label" parent="TextAppearance.SimplStream">
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:textSize">12sp</item>
    </style>
    
    <style name="Widget.SimplStream.Button" parent="android:Widget.Button">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:focusable">true</item>
    </style>
    
    <!-- Force Outfit font on ALL TextViews (overrides Leanback/AppCompat defaults) -->
    <style name="Widget.SimplStream.TextView" parent="android:Widget.TextView">
        <item name="android:fontFamily">@font/outfit_medium</item>
    </style>

    <style name="Widget.SimplStream" parent="android:Widget">
        <item name="android:focusable">true</item>
    </style>
    
    <style name="Widget.SimplStream.Card" parent="Widget.SimplStream">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:clickable">true</item>
    </style>

    <!-- ==================== TYPOGRAPHY ==================== -->
    
    <!-- Display Headings (Outfit - for titles, hero text) -->
    <style name="TextAppearance.SimplStream.Display.Large">
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textSize">56sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Display.Medium">
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textSize">40sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Display.Small">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- Headlines (Outfit) -->
    <style name="TextAppearance.SimplStream.Headline.Large">
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Headline.Medium">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Headline.Small">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- Titles (Outfit) -->
    <style name="TextAppearance.SimplStream.Title.Large">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Title.Medium">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SimplStream.Title.Small">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- Body Text (Plus Jakarta Sans - for descriptions, paragraphs) -->
    <style name="TextAppearance.SimplStream.Body.Large">
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextAppearance.SimplStream.Body.Medium">
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.SimplStream.Body.Small">
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- Labels (Plus Jakarta Sans) -->
    <style name="TextAppearance.SimplStream.Label.Large">
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Label.Medium">
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>
    
    <style name="TextAppearance.SimplStream.Label.Small">
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
    
    <!-- Nav Tab Style -->
    <style name="TextAppearance.SimplStream.NavTab">
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
    
    <style name="TextAppearance.SimplStream.NavTab.Active">
        <item name="android:fontFamily">@font/plus_jakarta_sans_bold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/simpl_blue</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
    
    <!-- ==================== BUTTONS ==================== -->
    
    <!-- Primary Button (Blue, rounded) -->
    <style name="Widget.SimplStream.Button.Primary">
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:paddingHorizontal">32dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:focusable">true</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="backgroundTint">@null</item>
    </style>

    <!-- Secondary Button (Glass/Transparent) -->
    <style name="Widget.SimplStream.Button.Secondary">
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:paddingHorizontal">32dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:focusable">true</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="backgroundTint">@null</item>
    </style>
    
    <!-- ==================== CARDS ==================== -->
    
    <!-- Landscape Content Card -->
    <style name="Widget.SimplStream.Card.Landscape">
        <item name="android:background">@drawable/bg_landscape_card</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>
    
    <!-- Glass Panel (for overlays) -->
    <style name="Widget.SimplStream.GlassPanel">
        <item name="android:background">@drawable/bg_glass_panel</item>
        <item name="android:padding">16dp</item>
    </style>
    
    <!-- ==================== RATING BADGE ==================== -->
    
    <style name="Widget.SimplStream.RatingBadge">
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/bg_rating_badge</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">4dp</item>
    </style>
    
</resources>
