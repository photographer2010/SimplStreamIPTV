<?xml version="1.0" encoding="utf-8"?>
<!-- Personalized Recommendation Card -->
<!-- Netflix-style card with match percentage and AI indicators -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/card_margin"
    android:clipToPadding="false"
    android:clipChildren="false"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardBackgroundColor="@color/brand_card"
        app:cardElevation="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Backdrop Image (16:9 aspect ratio) -->
            <ImageView
                android:id="@+id/backdrop_image"
                android:layout_width="match_parent"
                android:layout_height="135dp"
                android:scaleType="centerCrop"
                tools:background="@color/brand_card_elevated" />

            <!-- Gradient overlay for text legibility -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_hero_bottom" />

            <!-- Match Percentage Badge (top-left) -->
            <TextView
                android:id="@+id/match_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_match_badge"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="@font/outfit_bold"
                tools:text="95% Match" />

            <!-- New/Trending Badge (top-right) -->
            <TextView
                android:id="@+id/status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_status_badge"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:fontFamily="@font/outfit_bold"
                android:visibility="gone"
                tools:text="NEW"
                tools:visibility="visible" />

            <!-- Media Type Indicator (hidden) -->
            <View
                android:id="@+id/type_indicator"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/simpl_blue"
                android:visibility="gone" />

            <!-- Rating Badge (bottom-left of image) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_glass_panel"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_star"
                    app:tint="@color/rating_gold" />

                <TextView
                    android:id="@+id/rating_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:fontFamily="@font/outfit_medium"
                    tools:text="8.5" />

            </LinearLayout>

            <!-- Focus border overlay -->
            <View
                android:id="@+id/focus_border"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_card_focused"
                android:visibility="invisible" />

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Content Info (below card) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginTop="135dp"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingHorizontal="4dp">

        <!-- Title -->
        <TextView
            android:id="@+id/title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="@font/outfit_semibold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Recommended Title" />

        <!-- Match Reason -->
        <TextView
            android:id="@+id/match_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="@font/plus_jakarta_sans_regular"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Action • 2024" />

    </LinearLayout>

</FrameLayout>
