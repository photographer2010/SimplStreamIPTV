<?xml version="1.0" encoding="utf-8"?>
<!-- Content row layout with title and horizontal scroll -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="@dimen/row_spacing"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Row Title -->
    <TextView
        android:id="@+id/row_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/row_margin_horizontal"
        android:layout_marginBottom="@dimen/row_title_margin_bottom"
        style="@style/TextAppearance.SimplStream.Headline.Small"
        tools:text="Trending Now" />

    <!-- Horizontal RecyclerView for cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/row_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/row_margin_horizontal"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:overScrollMode="never"
        android:focusable="false" />

</LinearLayout>
