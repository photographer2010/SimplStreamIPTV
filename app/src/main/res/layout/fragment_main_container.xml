<?xml version="1.0" encoding="utf-8"?>
<!-- Main Container with Netflix-style header navigation -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark">

    <!-- Content Area (fragments load here) -->
    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Header Navigation Overlay (gradient background) -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_gradient"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="@dimen/header_padding_horizontal">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Logo: "Simpl" (blue) + "Stream" (white) -->
            <LinearLayout
                android:id="@+id/logo_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Simpl"
                    android:textColor="@color/simpl_blue"
                    android:textSize="22sp"
                    android:fontFamily="@font/outfit_bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stream"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="@font/outfit_bold"
                    android:letterSpacing="-0.02" />

            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Navigation Tabs -->
            <HorizontalScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginStart="32dp">

                <LinearLayout
                    android:id="@+id/nav_tabs_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tab_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOME"
                        style="@style/TextAppearance.SimplStream.NavTab"
                        android:textColor="@color/simpl_blue"
                        android:padding="12dp"
                        android:layout_marginEnd="@dimen/nav_tab_spacing"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:background="@drawable/bg_nav_tab_focus" />

                    <TextView
                        android:id="@+id/tab_movies"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOVIES"
                        style="@style/TextAppearance.SimplStream.NavTab"
                        android:textColor="@color/text_secondary"
                        android:padding="12dp"
                        android:layout_marginEnd="@dimen/nav_tab_spacing"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:background="@drawable/bg_nav_tab_focus" />

                    <TextView
                        android:id="@+id/tab_tv_shows"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TV SHOWS"
                        style="@style/TextAppearance.SimplStream.NavTab"
                        android:textColor="@color/text_secondary"
                        android:padding="12dp"
                        android:layout_marginEnd="@dimen/nav_tab_spacing"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:background="@drawable/bg_nav_tab_focus" />

                    <TextView
                        android:id="@+id/tab_my_list"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MY LIST"
                        style="@style/TextAppearance.SimplStream.NavTab"
                        android:textColor="@color/text_secondary"
                        android:padding="12dp"
                        android:layout_marginEnd="@dimen/nav_tab_spacing"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:background="@drawable/bg_nav_tab_focus" />

                    <!-- For You - AI Personalized Recommendations -->
                    <TextView
                        android:id="@+id/tab_for_you"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FOR YOU"
                        style="@style/TextAppearance.SimplStream.NavTab"
                        android:textColor="@color/text_secondary"
                        android:padding="12dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:background="@drawable/bg_nav_tab_focus" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Right side icons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="24dp">

                <ImageView
                    android:id="@+id/btn_search"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_search"
                    android:padding="12dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/bg_icon_focus"
                    app:tint="@color/text_primary"
                    android:contentDescription="Search" />

                <ImageView
                    android:id="@+id/btn_profile"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_person"
                    android:padding="12dp"
                    android:layout_marginStart="8dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/bg_icon_focus"
                    app:tint="@color/text_primary"
                    android:contentDescription="Profile" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
