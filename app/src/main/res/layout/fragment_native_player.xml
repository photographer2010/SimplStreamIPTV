<?xml version="1.0" encoding="utf-8"?>
<!-- Clean Player UI - All controls at bottom bar only -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ExoPlayer View -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:show_buffering="when_playing"
        app:use_controller="false"
        app:resize_mode="fit"
        app:shutter_background_color="@android:color/black"
        app:surface_type="surface_view"
        app:keep_content_on_player_reset="true"
        app:use_artwork="false" />

    <!-- Subtitle View -->
    <androidx.media3.ui.SubtitleView
        android:id="@+id/subtitle_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom|center_horizontal"
        android:paddingHorizontal="64dp"
        android:paddingBottom="140dp" />

    <!-- Skip Backward Indicator -->
    <LinearLayout
        android:id="@+id/skip_backward_indicator"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="80dp"
        android:background="@drawable/bg_skip_indicator"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_replay_10"
            app:tint="@android:color/white" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="10s"
            android:textColor="@android:color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Skip Forward Indicator -->
    <LinearLayout
        android:id="@+id/skip_forward_indicator"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="80dp"
        android:background="@drawable/bg_skip_indicator"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_forward_10"
            app:tint="@android:color/white" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="10s"
            android:textColor="@android:color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Loading Overlay -->
    <LinearLayout
        android:id="@+id/loading_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">
        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="@color/simpl_blue" />
        <TextView
            android:id="@+id/loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="@font/outfit_bold"
            android:text="Loading..." />
        <TextView
            android:id="@+id/loading_subtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:fontFamily="@font/outfit_medium"
            android:text="Fetching stream" />
    </LinearLayout>

    <!-- Error Overlay -->
    <LinearLayout
        android:id="@+id/error_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="48dp">
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_error"
            app:tint="@color/error" />
        <TextView
            android:id="@+id/error_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:gravity="center"
            tools:text="Unable to Play" />
        <TextView
            android:id="@+id/error_subtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            android:gravity="center"
            android:text="Stream unavailable" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">
            <Button
                android:id="@+id/retry_button"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Retry"
                android:background="@drawable/bg_button_primary"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:paddingHorizontal="28dp"
                android:focusable="true" />
            <Button
                android:id="@+id/try_next_button"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:text="Next Stream"
                android:background="@drawable/bg_button_secondary"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingHorizontal="28dp"
                android:focusable="true" />
            <Button
                android:id="@+id/why_button"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:text="Why?"
                android:background="@drawable/bg_button_secondary"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingHorizontal="28dp"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- ==================== NEXT EPISODE CARD (Bottom Right) ==================== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/next_episode_overlay"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="160dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#E6141418"
        app:cardElevation="8dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header with countdown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Up Next"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/outfit_medium" />

                <!-- Countdown timer -->
                <TextView
                    android:id="@+id/next_episode_countdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:textColor="@color/simpl_blue"
                    android:textSize="14sp"
                    android:fontFamily="@font/outfit_bold" />
            </LinearLayout>

            <!-- Episode preview row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- Episode thumbnail -->
                <ImageView
                    android:id="@+id/next_episode_thumbnail"
                    android:layout_width="100dp"
                    android:layout_height="56dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_card"
                    tools:src="@color/surface_elevated" />

                <!-- Episode info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/next_episode_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/outfit_semibold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="Episode 5" />

                    <TextView
                        android:id="@+id/next_episode_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="The Next Chapter" />
                </LinearLayout>
            </LinearLayout>

            <!-- Buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Close / Wait button -->
                <Button
                    android:id="@+id/replay_button"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Close"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/outfit_medium"
                    android:focusable="true"
                    android:nextFocusRight="@id/next_episode_button"
                    android:nextFocusLeft="@id/next_episode_button" />

                <!-- Play Next button -->
                <Button
                    android:id="@+id/next_episode_button"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_primary"
                    android:text="Play Next"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:fontFamily="@font/outfit_semibold"
                    android:focusable="true"
                    android:nextFocusLeft="@id/replay_button"
                    android:nextFocusRight="@id/replay_button" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Center Play/Pause Animation -->
    <ImageView
        android:id="@+id/play_pause_indicator"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_pause"
        app:tint="@android:color/white"
        android:alpha="0"
        android:visibility="gone" />

    <!-- ==================== BOTTOM CONTROL BAR ==================== -->
    <LinearLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_player_controls"
        android:orientation="vertical"
        android:paddingHorizontal="40dp"
        android:paddingTop="40dp"
        android:paddingBottom="20dp"
        android:visibility="visible">

        <!-- Title Row (hidden in minimal mode) -->
        <LinearLayout
            android:id="@+id/title_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageButton
                android:id="@+id/back_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                app:tint="@android:color/white"
                android:background="@drawable/bg_player_btn"
                android:scaleType="centerInside"
                android:contentDescription="Back"
                android:focusable="true" />

            <TextView
                android:id="@+id/title_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:fontFamily="@font/outfit_bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Movie Title" />

            <TextView
                android:id="@+id/quality_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:fontFamily="@font/outfit_bold"
                android:background="@drawable/bg_quality_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                tools:text="1080p" />
        </LinearLayout>

        <!-- Progress Bar -->
        <LinearLayout
            android:id="@+id/progress_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/current_time_text"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:fontFamily="@font/outfit_semibold"
                tools:text="0:00:00" />

            <SeekBar
                android:id="@+id/progress_seekbar"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="16dp"
                android:max="1000"
                android:progress="0"
                android:progressDrawable="@drawable/bg_seekbar_track"
                android:thumb="@drawable/bg_seekbar_thumb"
                android:thumbOffset="0dp"
                android:splitTrack="false"
                android:focusable="true"
                android:paddingStart="0dp"
                android:paddingEnd="0dp" />

            <TextView
                android:id="@+id/total_time_text"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/outfit_semibold"
                android:gravity="end"
                tools:text="2:15:30" />
        </LinearLayout>

        <!-- Playback Controls Row (hidden in minimal mode) -->
        <LinearLayout
            android:id="@+id/controls_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left Side: Source Button -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="start|center_vertical">

                <TextView
                    android:id="@+id/source_button"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_source_btn"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="@font/outfit_semibold"
                    android:focusable="true"
                    tools:text="Sources (3)" />
            </LinearLayout>

            <!-- Center: Rewind, Play/Pause, Forward -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/rewind_button"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_rewind_10"
                    app:tint="@android:color/white"
                    android:background="@drawable/bg_player_btn"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:focusable="true"
                    android:contentDescription="Rewind 10 seconds" />

                <ImageButton
                    android:id="@+id/play_pause_button"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="24dp"
                    android:src="@drawable/ic_pause"
                    app:tint="@android:color/white"
                    android:background="@drawable/bg_play_btn"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:focusable="true"
                    android:contentDescription="Play/Pause" />

                <ImageButton
                    android:id="@+id/forward_button"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_forward_10"
                    app:tint="@android:color/white"
                    android:background="@drawable/bg_player_btn"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:focusable="true"
                    android:contentDescription="Forward 10 seconds" />
            </LinearLayout>

            <!-- Right Side: Subtitles, Settings -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="end|center_vertical">

                <ImageButton
                    android:id="@+id/subtitles_button"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_subtitles"
                    app:tint="@android:color/white"
                    android:background="@drawable/bg_player_btn"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:focusable="true"
                    android:contentDescription="Subtitles" />

                <ImageButton
                    android:id="@+id/settings_button"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_settings"
                    app:tint="@android:color/white"
                    android:background="@drawable/bg_player_btn"
                    android:scaleType="centerInside"
                    android:padding="10dp"
                    android:focusable="true"
                    android:contentDescription="Settings" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Settings Hint - Two-line footer for D-pad users -->
    <LinearLayout
        android:id="@+id/settings_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="4dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Press BACK for more settings"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_semibold"
            android:alpha="0.7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Skip 10s by pressing left or right"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_medium"
            android:alpha="0.5" />
    </LinearLayout>

    <!-- Compatibility views (required by code) -->
    <TextView android:id="@+id/aspect_button" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" />
    <ImageButton android:id="@+id/volume_button" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" />
    <SeekBar android:id="@+id/volume_seekbar" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" />
    <View android:id="@+id/top_bar" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" />
    <View android:id="@+id/center_controls" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" />

    <!-- ==================== PLAYER SETTINGS SIDEBAR ==================== -->
    <LinearLayout
        android:id="@+id/stream_sidebar"
        android:layout_width="360dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#F5101014"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        android:elevation="16dp"
        android:descendantFocusability="afterDescendants">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Player Settings"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="@font/outfit_bold" />

            <ImageButton
                android:id="@+id/close_sidebar_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close"
                app:tint="@color/text_secondary"
                android:background="@drawable/bg_player_btn"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusDown="@id/setting_quality" />
        </LinearLayout>

        <!-- Quality Setting -->
        <LinearLayout
            android:id="@+id/setting_quality"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_sidebar_item"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/setting_subtitles"
            android:nextFocusUp="@id/close_sidebar_button">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_quality"
                app:tint="@color/simpl_blue" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="Quality"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/outfit_medium" />

            <TextView
                android:id="@+id/quality_selector_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/text_tertiary" />
        </LinearLayout>

        <!-- Subtitles Setting -->
        <LinearLayout
            android:id="@+id/setting_subtitles"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_sidebar_item"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@id/setting_quality"
            android:nextFocusDown="@id/setting_aspect">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_subtitles"
                app:tint="@color/simpl_blue" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="Subtitles"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/outfit_medium" />

            <TextView
                android:id="@+id/subtitles_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Off"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/text_tertiary" />
        </LinearLayout>

        <!-- Aspect Ratio Setting -->
        <LinearLayout
            android:id="@+id/setting_aspect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_sidebar_item"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@id/setting_subtitles"
            android:nextFocusDown="@id/stream_list">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_aspect_ratio"
                app:tint="@color/simpl_blue" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="Aspect Ratio"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/outfit_medium" />

            <TextView
                android:id="@+id/aspect_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FIT"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/text_tertiary" />
        </LinearLayout>

        <!-- Servers Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available Streams"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/outfit_medium"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/stream_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@id/setting_aspect" />

    </LinearLayout>

</FrameLayout>
