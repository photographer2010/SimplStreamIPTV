<?xml version="1.0" encoding="utf-8"?>
<!-- Netflix-style Profile Card - Compact Horizontal for TV -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="100dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="10dp"
    android:layout_marginHorizontal="12dp"
    android:background="@drawable/bg_profile_card"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Avatar Container with ring effect on focus -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="8dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Focus ring (shown when focused) -->
        <View
            android:id="@+id/focus_ring"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_cast_focus_ring"
            android:visibility="invisible" />

        <!-- Avatar background -->
        <View
            android:id="@+id/avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_avatar_circle" />

        <!-- Avatar initial/emoji -->
        <TextView
            android:id="@+id/avatar_initial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:fontFamily="@font/outfit_bold"
            tools:text="J" />

        <!-- PIN Lock Badge -->
        <FrameLayout
            android:id="@+id/pin_badge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_circle_button"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                app:tint="@android:color/white" />
        </FrameLayout>

    </FrameLayout>

    <!-- Name -->
    <TextView
        android:id="@+id/profile_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:fontFamily="@font/outfit_semibold"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="John" />

    <!-- Kids Badge -->
    <LinearLayout
        android:id="@+id/kids_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_genre_chip"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KIDS"
            android:textColor="@color/simpl_blue"
            android:textSize="10sp"
            android:fontFamily="@font/outfit_bold"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <!-- Hidden legacy views for compatibility -->
    <View
        android:id="@+id/pin_icon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <View
        android:id="@+id/kids_label"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
