<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Ambient glow behind the text (subtle blue radial pulse) -->
    <View
        android:id="@+id/ambient_glow"
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:layout_gravity="center"
        android:alpha="0"
        android:background="@drawable/bg_splash_glow" />

    <!-- "Simpl" text — starts centered, will animate -->
    <TextView
        android:id="@+id/text_simpl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Simpl"
        android:textColor="@color/simpl_blue"
        android:textSize="52sp"
        android:fontFamily="@font/outfit_bold"
        android:letterSpacing="-0.02"
        android:alpha="0" />

    <!-- "Stream" text — starts hidden, appears after Simpl moves -->
    <TextView
        android:id="@+id/text_stream"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Stream"
        android:textColor="@color/text_primary"
        android:textSize="52sp"
        android:fontFamily="@font/outfit_bold"
        android:letterSpacing="-0.02"
        android:alpha="0" />

    <!-- Combined "SimplStream" — used for final merge + zoom -->
    <LinearLayout
        android:id="@+id/text_combined"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:alpha="0">

        <TextView
            android:id="@+id/text_combined_simpl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Simpl"
            android:textColor="@color/simpl_blue"
            android:textSize="52sp"
            android:fontFamily="@font/outfit_bold"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/text_combined_stream"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stream"
            android:textColor="@color/text_primary"
            android:textSize="52sp"
            android:fontFamily="@font/outfit_bold"
            android:letterSpacing="-0.02" />
    </LinearLayout>

    <!-- Particle/spark effect layer (optional visual flair) -->
    <View
        android:id="@+id/flash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:alpha="0" />

</FrameLayout>
