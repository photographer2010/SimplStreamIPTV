<?xml version="1.0" encoding="utf-8"?>
<!-- For You - Personalized Recommendations Page -->
<!-- Netflix-style AI-powered recommendation experience -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark"
    android:fillViewport="true"
    android:overScrollMode="never">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Loading State -->
        <LinearLayout
            android:id="@+id/loading_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminateTint="@color/simpl_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Analyzing your taste..."
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:fontFamily="@font/outfit_medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Finding perfect matches"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:fontFamily="@font/plus_jakarta_sans_regular" />

        </LinearLayout>

        <!-- Error State -->
        <LinearLayout
            android:id="@+id/error_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="48dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_sparkle"
                app:tint="@color/text_muted"
                android:alpha="0.5" />

            <TextView
                android:id="@+id/error_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Couldn't load recommendations"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:fontFamily="@font/outfit_semibold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Watch some content to get personalized suggestions"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:gravity="center" />

            <Button
                android:id="@+id/retry_button"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="24dp"
                android:text="Try Again"
                style="@style/Widget.SimplStream.Button.Secondary" />

        </LinearLayout>

        <!-- Main Content -->
        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===================== SPOTLIGHT HERO ===================== -->
            <FrameLayout
                android:id="@+id/spotlight_container"
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:visibility="gone">

                <!-- Gradient Background -->
                <View
                    android:id="@+id/spotlight_gradient"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_spotlight_gradient" />

                <!-- Backdrop Image -->
                <ImageView
                    android:id="@+id/spotlight_backdrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:alpha="0.6"
                    tools:background="@color/brand_card" />

                <!-- Content Overlay -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="@dimen/screen_padding"
                    android:background="@drawable/gradient_hero_bottom">

                    <!-- AI Badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_ai_badge"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_sparkle"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/spotlight_tagline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:fontFamily="@font/outfit_semibold"
                            tools:text="Perfect for you tonight" />

                    </LinearLayout>

                    <!-- Title -->
                    <TextView
                        android:id="@+id/spotlight_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:maxWidth="500dp"
                        style="@style/TextAppearance.SimplStream.Display.Medium"
                        tools:text="Spotlight Title" />

                    <!-- Match Score + Metadata -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Match Percentage -->
                        <TextView
                            android:id="@+id/spotlight_match"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/success_match"
                            android:textSize="15sp"
                            android:fontFamily="@font/outfit_bold"
                            tools:text="95% Match" />

                        <View
                            android:layout_width="4dp"
                            android:layout_height="4dp"
                            android:layout_marginHorizontal="12dp"
                            android:background="@drawable/bg_current_server_dot" />

                        <!-- Rating -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_star"
                                app:tint="@color/rating_gold" />

                            <TextView
                                android:id="@+id/spotlight_rating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="@font/outfit_medium"
                                tools:text="8.5" />

                        </LinearLayout>

                        <View
                            android:layout_width="4dp"
                            android:layout_height="4dp"
                            android:layout_marginHorizontal="12dp"
                            android:background="@drawable/bg_current_server_dot" />

                        <!-- Year -->
                        <TextView
                            android:id="@+id/spotlight_year"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            tools:text="2024" />

                    </LinearLayout>

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/spotlight_play_button"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/button_height_large"
                            android:minWidth="140dp"
                            android:text="@string/action_play"
                            android:drawableStart="@drawable/ic_play_arrow"
                            android:drawablePadding="8dp"
                            android:drawableTint="@color/white"
                            style="@style/Widget.SimplStream.Button.Primary"
                            android:focusable="true"
                            android:focusableInTouchMode="true" />

                        <Button
                            android:id="@+id/spotlight_info_button"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/button_height_large"
                            android:text="More Info"
                            android:drawableStart="@drawable/ic_info"
                            android:drawablePadding="8dp"
                            android:drawableTint="@color/white"
                            android:layout_marginStart="12dp"
                            style="@style/Widget.SimplStream.Button.Secondary"
                            android:focusable="true"
                            android:focusableInTouchMode="true" />

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- ===================== PAGE HEADER ===================== -->
            <LinearLayout
                android:id="@+id/header_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="32dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- AI Sparkle Icon -->
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_sparkle"
                        app:tint="@color/simpl_blue" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="For You"
                        style="@style/TextAppearance.SimplStream.Display.Small" />

                    <!-- Refresh Button -->
                    <ImageView
                        android:id="@+id/refresh_button"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_refresh"
                        app:tint="@color/text_secondary"
                        android:background="@drawable/bg_circle_button"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:contentDescription="Refresh recommendations" />

                </LinearLayout>

                <!-- Subtitle with taste info -->
                <TextView
                    android:id="@+id/subtitle_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    tools:text="Based on your love for Action, Sci-Fi, and Thriller" />

            </LinearLayout>

            <!-- ===================== SECTIONS CONTAINER ===================== -->
            <LinearLayout
                android:id="@+id/sections_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="48dp" />

        </LinearLayout>

    </FrameLayout>

</androidx.core.widget.NestedScrollView>
