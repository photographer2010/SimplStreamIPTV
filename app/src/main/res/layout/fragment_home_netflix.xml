<?xml version="1.0" encoding="utf-8"?>
<!-- Netflix-style Home Fragment with Hero Carousel -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="0dp">

        <!-- Hero Carousel Section -->
        <FrameLayout
            android:id="@+id/hero_container"
            android:layout_width="match_parent"
            android:layout_height="@dimen/hero_height">

            <!-- Hero Background Image -->
            <ImageView
                android:id="@+id/hero_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:background="@color/brand_card" />

            <!-- Hero Gradient Overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_hero_gradient" />

            <!-- Hero Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/row_margin_horizontal"
                android:paddingBottom="32dp">

                <!-- Logo/Title for featured content -->
                <TextView
                    android:id="@+id/hero_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.SimplStream.Display.Large"
                    android:maxLines="2"
                    android:maxWidth="600dp"
                    tools:text="Featured Movie Title" />

                <!-- Metadata row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical">

                    <!-- Rating Badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_rating_badge"
                        android:paddingHorizontal="@dimen/rating_badge_padding_horizontal"
                        android:paddingVertical="@dimen/rating_badge_padding_vertical"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_star"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/hero_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:fontFamily="@font/outfit_bold"
                            tools:text="8.5" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/hero_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        tools:text="2024" />

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@color/text_muted" />

                    <TextView
                        android:id="@+id/hero_genre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        tools:text="Action • Adventure" />

                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:id="@+id/hero_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:maxWidth="700dp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    style="@style/TextAppearance.SimplStream.Body.Medium"
                    tools:text="A thrilling adventure across the galaxy..." />

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">

                    <Button
                        android:id="@+id/btn_play"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_large"
                        android:text="Play"
                        android:drawableStart="@drawable/ic_play_arrow"
                        android:drawablePadding="8dp"
                        style="@style/Widget.SimplStream.Button.Primary"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <Button
                        android:id="@+id/btn_more_info"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_large"
                        android:text="More Info"
                        android:drawableStart="@drawable/ic_info"
                        android:drawablePadding="8dp"
                        android:layout_marginStart="16dp"
                        style="@style/Widget.SimplStream.Button.Secondary"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- Carousel Dots Indicator -->
            <LinearLayout
                android:id="@+id/dots_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal" />

        </FrameLayout>

        <!-- Content Rows Container -->
        <LinearLayout
            android:id="@+id/rows_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="48dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
