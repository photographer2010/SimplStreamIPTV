<?xml version="1.0" encoding="utf-8"?>
<!-- Netflix-style Landscape Episode Card -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:clipToPadding="false"
    android:clipChildren="false"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardBackgroundColor="@color/brand_card"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Episode Still/Thumbnail -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp">

                <ImageView
                    android:id="@+id/still_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    tools:background="@color/brand_card_elevated" />

                <!-- Gradient overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/gradient_hero_bottom" />

                <!-- Episode Number Badge -->
                <TextView
                    android:id="@+id/episode_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="12dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/bg_episode_badge"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:fontFamily="@font/outfit_bold"
                    tools:text="E1" />

                <!-- Runtime badge (bottom right) -->
                <TextView
                    android:id="@+id/runtime_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_glass_panel"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="@font/outfit_medium"
                    tools:text="45 min" />

                <!-- Play overlay icon (shows on focus) -->
                <FrameLayout
                    android:id="@+id/play_overlay"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_play_button"
                    android:visibility="invisible">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_arrow"
                        app:tint="@color/white" />

                </FrameLayout>

                <!-- Progress bar (if partially watched) -->
                <ProgressBar
                    android:id="@+id/watch_progress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_gravity="bottom"
                    android:max="100"
                    android:progressDrawable="@drawable/progress_watch"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- Episode Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Episode code -->
                <TextView
                    android:id="@+id/episode_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/simpl_blue"
                    android:textSize="12sp"
                    android:fontFamily="@font/outfit_semibold"
                    tools:text="S01 • E01" />

                <!-- Episode Title -->
                <TextView
                    android:id="@+id/episode_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="@font/outfit_semibold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Pilot Episode Title" />

                <!-- Episode Overview -->
                <TextView
                    android:id="@+id/episode_overview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    android:lineSpacingMultiplier="1.3"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="A young hero discovers their extraordinary abilities and must learn to control them." />

            </LinearLayout>

        </LinearLayout>

        <!-- Focus border overlay -->
        <View
            android:id="@+id/focus_border"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card_focused"
            android:visibility="invisible" />

    </androidx.cardview.widget.CardView>

</FrameLayout>
