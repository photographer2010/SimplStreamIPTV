<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:layout_margin="4dp"
    android:background="@drawable/bg_episode_card"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:clickable="true">

    <!-- Episode Still/Thumbnail -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="100dp">

        <ImageView
            android:id="@+id/still_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/background_tertiary" />

        <!-- Episode number badge -->
        <TextView
            android:id="@+id/episode_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="6dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_episode_badge"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_semibold"
            tools:text="E1" />

        <!-- Play overlay on focus -->
        <ImageView
            android:id="@+id/play_overlay"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play_circle"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Episode Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/episode_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/simpl_blue"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_semibold"
            android:maxLines="1"
            tools:text="S01E01 • 45m" />

        <TextView
            android:id="@+id/episode_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="@font/outfit_medium"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="Episode Title Goes Here" />

    </LinearLayout>

</LinearLayout>
