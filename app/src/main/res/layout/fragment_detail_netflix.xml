<?xml version="1.0" encoding="utf-8"?>
<!-- Netflix-style Detail Page with Glass Morphism -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_dark"
    android:fillViewport="true"
    android:overScrollMode="never">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Loading View -->
        <LinearLayout
            android:id="@+id/loading_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminateTint="@color/simpl_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Loading..."
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Error View -->
        <LinearLayout
            android:id="@+id/error_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_error"
                app:tint="@color/text_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/error_loading"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/retry_button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="Retry"
                style="@style/Widget.SimplStream.Button.Secondary" />

        </LinearLayout>

        <!-- Content -->
        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===================== HERO SECTION ===================== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/detail_backdrop_height">

                <!-- Full-width Backdrop -->
                <ImageView
                    android:id="@+id/backdrop_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    tools:background="@color/brand_card" />

                <!-- Back Button -->
                <ImageView
                    android:id="@+id/back_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="@dimen/screen_padding"
                    android:layout_marginTop="24dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/white"
                    android:background="@drawable/bg_glass_circle"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:defaultFocusHighlightEnabled="false"
                    android:contentDescription="Go back" />

            </FrameLayout>

            <!-- ===================== MAIN INFO SECTION ===================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/screen_padding"
                android:layout_marginTop="-120dp">

                <!-- Poster with rounded corners -->
                <androidx.cardview.widget.CardView
                    android:layout_width="@dimen/detail_poster_width"
                    android:layout_height="@dimen/detail_poster_height"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    android:stateListAnimator="@null">

                    <ImageView
                        android:id="@+id/poster_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        tools:background="@color/brand_card_elevated" />

                </androidx.cardview.widget.CardView>

                <!-- Info Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="130dp">

                    <!-- Title -->
                    <TextView
                        android:id="@+id/title_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="600dp"
                        style="@style/TextAppearance.SimplStream.Display.Medium"
                        tools:text="Movie Title Here" />

                    <!-- Metadata Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Rating Badge -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rating_badge"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_star"
                                app:tint="@color/rating_gold" />

                            <TextView
                                android:id="@+id/rating_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/rating_gold"
                                android:textSize="12sp"
                                android:fontFamily="@font/outfit_bold"
                                tools:text="8.5" />

                        </LinearLayout>

                        <!-- Year -->
                        <TextView
                            android:id="@+id/year_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="15sp"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            tools:text="2024" />

                        <View
                            android:layout_width="4dp"
                            android:layout_height="4dp"
                            android:layout_marginHorizontal="12dp"
                            android:background="@drawable/bg_current_server_dot" />

                        <!-- Runtime / Seasons -->
                        <TextView
                            android:id="@+id/runtime_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="15sp"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            tools:text="2h 15m" />

                        <!-- HD Badge (optional) -->
                        <TextView
                            android:id="@+id/quality_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/bg_quality_badge"
                            android:textColor="@color/text_primary"
                            android:textSize="10sp"
                            android:fontFamily="@font/outfit_bold"
                            android:text="HD" />

                    </LinearLayout>

                    <!-- Genres -->
                    <TextView
                        android:id="@+id/genres_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/text_tertiary"
                        android:textSize="14sp"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        tools:text="Action • Adventure • Sci-Fi" />

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:orientation="horizontal">

                        <!-- Primary Play Button -->
                        <Button
                            android:id="@+id/play_button"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/button_height_large"
                            android:minWidth="160dp"
                            android:text="@string/action_play"
                            android:drawableStart="@drawable/ic_play_arrow"
                            android:drawablePadding="12dp"
                            android:drawableTint="@color/white"
                            style="@style/Widget.SimplStream.Button.Primary"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:defaultFocusHighlightEnabled="false" />

                        <!-- Add to List Button -->
                        <Button
                            android:id="@+id/watchlist_button"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/button_height_large"
                            android:text="@string/action_add_to_list"
                            android:drawableStart="@drawable/ic_add"
                            android:drawablePadding="8dp"
                            android:drawableTint="@color/white"
                            android:layout_marginStart="16dp"
                            style="@style/Widget.SimplStream.Button.Secondary"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:defaultFocusHighlightEnabled="false" />

                    </LinearLayout>

                    <!-- Resume Progress Bar -->
                    <LinearLayout
                        android:id="@+id/resume_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ProgressBar
                            android:id="@+id/resume_progress"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="160dp"
                            android:layout_height="4dp"
                            android:max="100"
                            android:progressDrawable="@drawable/progress_watch" />

                        <TextView
                            android:id="@+id/resume_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            tools:text="45% watched" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ===================== OVERVIEW SECTION ===================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="@dimen/screen_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overview"
                    style="@style/TextAppearance.SimplStream.Headline.Small" />

                <TextView
                    android:id="@+id/overview_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:maxWidth="900dp"
                    style="@style/TextAppearance.SimplStream.Body.Medium"
                    tools:text="A thrilling adventure that takes you through the cosmos..." />

                <!-- Director/Creator info -->
                <LinearLayout
                    android:id="@+id/director_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Director: "
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:fontFamily="@font/plus_jakarta_sans_regular" />

                    <TextView
                        android:id="@+id/director_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        tools:text="Christopher Nolan" />

                </LinearLayout>

            </LinearLayout>

            <!-- ===================== SEASONS/EPISODES (TV Only) ===================== -->
            <LinearLayout
                android:id="@+id/seasons_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp"
                android:visibility="gone">

                <!-- Section Header with Season Selector -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/screen_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Episodes"
                        style="@style/TextAppearance.SimplStream.Headline.Small" />

                    <!-- Season Selector Pill -->
                    <TextView
                        android:id="@+id/season_spinner"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="16dp"
                        android:paddingHorizontal="20dp"
                        android:gravity="center"
                        android:background="@drawable/bg_season_selector"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/outfit_medium"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:drawableEnd="@drawable/ic_dropdown"
                        android:drawablePadding="8dp"
                        android:drawableTint="@color/text_secondary"
                        tools:text="Season 1" />

                </LinearLayout>

                <!-- Episodes loading indicator -->
                <ProgressBar
                    android:id="@+id/episodes_loading"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:indeterminateTint="@color/simpl_blue"
                    android:visibility="gone" />

                <!-- Episodes Horizontal Scroll -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/episodes_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingHorizontal="@dimen/screen_padding"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ===================== CAST SECTION ===================== -->
            <LinearLayout
                android:id="@+id/cast_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/cast_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/screen_padding"
                    android:text="@string/cast_label"
                    style="@style/TextAppearance.SimplStream.Headline.Small" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/cast_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingHorizontal="@dimen/screen_padding"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            </LinearLayout>

            <!-- ===================== RECOMMENDATIONS ===================== -->
            <LinearLayout
                android:id="@+id/recommendations_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="48dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/screen_padding"
                    android:text="@string/more_like_this"
                    style="@style/TextAppearance.SimplStream.Headline.Small" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recommendations_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingHorizontal="@dimen/screen_padding"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.core.widget.NestedScrollView>
