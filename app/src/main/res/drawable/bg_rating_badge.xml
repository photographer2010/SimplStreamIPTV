<?xml version="1.0" encoding="utf-8"?>
<!-- Rating badge background - Modern glassmorphic style with gold accent -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow/glow layer -->
    <item android:bottom="1dp" android:left="1dp" android:right="-1dp" android:top="-1dp">
        <shape android:shape="rectangle">
            <solid android:color="#33F59E0B" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <!-- Main background with gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#F59E0B"
                android:centerColor="#D97706"
                android:endColor="#B45309"
                android:type="linear" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <!-- Inner highlight for glass effect -->
    <item android:bottom="0dp" android:left="0dp" android:right="0dp" android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#00FFFFFF"
                android:endColor="#22FFFFFF"
                android:type="linear" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</layer-list>
