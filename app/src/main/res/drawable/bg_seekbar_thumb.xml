<?xml version="1.0" encoding="utf-8"?>
<!-- Slim seekbar thumb with subtle glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#442563EB" />
            <size android:width="14dp" android:height="14dp" />
        </shape>
    </item>
    <!-- Inner circle -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/simpl_blue" />
        </shape>
    </item>
</layer-list>
