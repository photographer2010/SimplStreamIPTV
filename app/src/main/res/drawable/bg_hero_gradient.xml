<?xml version="1.0" encoding="utf-8"?>
<!-- Hero section gradient overlay - Dark fade at bottom, subtle vignette at top -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top subtle vignette for status bar area readability -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="180"
                android:startColor="#40000000"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Bottom fade — smooth transition into page background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="180"
                android:startColor="#00000000"
                android:centerColor="#66000000"
                android:centerY="0.55"
                android:endColor="@color/brand_dark" />
        </shape>
    </item>
</layer-list>
