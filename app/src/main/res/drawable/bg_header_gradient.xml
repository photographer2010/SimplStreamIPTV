<?xml version="1.0" encoding="utf-8"?>
<!-- Header gradient overlay - fades from dark to transparent -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="@color/brand_dark"
        android:centerColor="#CC0f1014"
        android:endColor="@color/transparent"/>
</shape>
