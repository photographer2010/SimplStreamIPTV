<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape content card with focus states - Netflix Style -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <!-- Blue glow border -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/simpl_blue"/>
                    <corners android:radius="@dimen/card_corner_radius"/>
                </shape>
            </item>
            <!-- Inner card -->
            <item
                android:left="3dp"
                android:top="3dp"
                android:right="3dp"
                android:bottom="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/brand_card"/>
                    <corners android:radius="14dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_card"/>
            <corners android:radius="@dimen/card_corner_radius"/>
        </shape>
    </item>
</selector>
